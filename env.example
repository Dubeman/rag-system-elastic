# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# LLM Configuration
LLM_SERVICE_URL=http://ollama:11434
LLM_MODEL_NAME=tinyllama
LLM_TIMEOUT=180

# Pipeline: v1 (Elasticsearch RAG) or v2 (vision-native)
PIPELINE_VERSION=v1

# Vision v2
V2_DATA_DIR=data/v2
COLPALI_USE_MOCK=true
RUNPOD_VLM_URL=
RUNPOD_API_KEY=
VLM_MODEL_NAME=microsoft/Phi-3.5-vision-instruct

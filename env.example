# Observability (API)
# Set to false to disable Prometheus /metrics and custom RAG counters.
METRICS_ENABLED=true

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# LLM Configuration
LLM_SERVICE_URL=http://ollama:11434
LLM_MODEL_NAME=tinyllama
LLM_TIMEOUT=180

# Pipeline: v1 (Elasticsearch RAG) or v2 (vision-native)
PIPELINE_VERSION=v1

# Vision v2
V2_DATA_DIR=data/v2
# Embeddings: mock | HTTP COLPALI_EMBED_URL | local (pip install -r requirements-colpali.txt, COLPALI_USE_MOCK=false)
COLPALI_USE_MOCK=true
COLPALI_MODEL_ID=vidore/colpali-v1.2
COLPALI_EMBED_URL=
COLPALI_EMBEDDING_DIM=128
# Vector index: faiss (default, on disk under V2_DATA_DIR) or qdrant
VECTOR_BACKEND=faiss
# Local: http://localhost:6333 — Docker Compose (service `qdrant`): http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=v2_pages
# VLM on RunPod (or OpenAI-compatible vision endpoint)
RUNPOD_VLM_URL=
RUNPOD_API_KEY=
VLM_MODEL_NAME=microsoft/Phi-3.5-vision-instruct
VLM_USE_OPENAI_COMPAT=false
VLM_MAX_TOKENS=1024

# Local mock VLM for development (scripts/mock_vlm_server.py); set RUNPOD_VLM_URL=http://127.0.0.1:9999/
# MOCK_VLM_PORT=9999
